# Discord Bot Configuration
# Copy file này thành .env và điền thông tin thật

# Discord Bot Token (BẮT BUỘC)
# Get from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Admin User IDs (Discord User IDs, ngăn cách bởi dấu phẩy)
# Get your ID: Discord Settings → Advanced → Developer Mode → Right click your name → Copy ID
ADMIN_IDS=123456789,987654321

# Database file path (Optional)
# Trên Railway nên dùng: /data/bot_database.json (nếu có volume)
DATABASE_FILE=bot_database.json

# Temp directory for conversions (Optional)
TEMP_DIR=temp_conversions
